# URL del progetto Supabase (Project Settings > API)
NUXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Chiave "anon public" (Project Settings > API) - esposta al client, protetta da RLS
NUXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Solo per lo script di seed locale (scripts/seed.mjs), NON usate dall'app ---
# Stesso URL del progetto
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Chiave "service_role" (Project Settings > API) - bypassa la RLS, NON esporla mai al client
# né committarla. Usala solo in locale per popolare il database di sviluppo.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
